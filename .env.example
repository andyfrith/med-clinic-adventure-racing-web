# Local PostgreSQL (Docker Compose)
DATABASE_URL=postgresql://medclinic:medclinic@localhost:5432/med_clinic_dev

# Neon (preview / production) — use connection string from Neon dashboard
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Auth.js base URL (local dev)
AUTH_URL=http://localhost:3000

# Vercel sets VERCEL_URL automatically; optional override for preview
# AUTH_URL=https://your-preview.vercel.app

# Vercel Preview deployments (per-PR URLs) — set in Vercel Preview env, not locally
# AUTH_TRUST_HOST=true
